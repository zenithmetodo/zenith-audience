{
  "mcpServers": {
    "apify": {
      "transport": "http",
      "url": "https://mcp.apify.com",
      "description": "Apify MCP oficial · scrapers Instagram · TikTok · YouTube · Facebook Ads · 5000+ actores. Plan Free $5/mes incluido.",
      "authentication": {
        "type": "bearer",
        "env_var": "APIFY_TOKEN"
      },
      "env": {
        "APIFY_TOKEN": "TU_TOKEN_AQUI"
      },
      "setup_instructions": [
        "1. Crear cuenta Apify Free en https://apify.com",
        "2. Obtener token en https://console.apify.com/account/integrations",
        "3. Añadir token a tu .env (NUNCA al repo · está en .gitignore)",
        "4. Instalar MCP:",
        "   claude mcp add --transport http apify https://mcp.apify.com --header \"Authorization=Bearer $APIFY_TOKEN\"",
        "5. Reiniciar Claude Code",
        "NOTA: Este archivo .json.example es solo DOCUMENTAL · el MCP HTTP se registra con el comando claude mcp add (paso 4)."
      ],
      "plan_free_limits": {
        "credit_mensual_usd": 5,
        "uso_estimado": "~2000 scrapes/mes (suficiente para uso individual)",
        "actores_disponibles": "5000+",
        "rate_limit": "Generoso para uso normal"
      },
      "actores_validados_zenith_audience": {
        "apify/instagram-scraper": {
          "uso": "Scraper general de Instagram (perfiles · hashtags · posts)",
          "agentes": ["spy-competidor", "engenharia-reversa"],
          "input_ejemplo": {
            "directUrls": ["https://www.instagram.com/nathan_perdriau/"],
            "resultsType": "posts",
            "resultsLimit": 50
          }
        },
        "apify/instagram-post-scraper": {
          "uso": "Scraper de posts específicos con views/likes/comments · OPTIMIZADO para análisis viral",
          "agentes": ["engenharia-reversa", "ideas-ganadoras-adapter"],
          "input_ejemplo": {
            "username": ["nathan_perdriau"],
            "resultsLimit": 50,
            "addParentData": false
          },
          "output_campos": ["url", "id", "likesCount", "commentsCount", "videoViewCount", "caption", "type", "ownerFollowersCount", "videoDuration"]
        },
        "curious_coder/facebook-ads-library-scraper": {
          "uso": "Spy de Meta Ads · creatividades activas · copy · imágenes/videos",
          "agentes": ["spy-competidor"],
          "input_ejemplo": {
            "searchTerms": ["fitness coach"],
            "country": "ES",
            "resultsLimit": 30
          }
        },
        "apidojo/tiktok-scraper-api": {
          "uso": "TikTok · views/likes/comments/shares · 50+ campos por vídeo",
          "agentes": ["trend-redes", "engenharia-reversa"]
        },
        "apify/instagram-hashtag-scraper": {
          "uso": "Posts top por hashtag · trending del momento",
          "agentes": ["trend-redes"]
        },
        "epctex/youtube-channel-scraper": {
          "uso": "YouTube · lista vídeos · stats · descripción",
          "agentes": ["spy-competidor", "trend-foros"]
        }
      },
      "agentes_que_lo_usan": [
        "spy-competidor",
        "trend-redes",
        "ideas-ganadoras-adapter",
        "asuntos-generator",
        "engenharia-reversa"
      ],
      "manejo_errores": {
        "no_configurado": "Cada agente detecta tools `mcp__apify__*` ausentes y entra en modo degradado · ver agente individual",
        "insufficient_credits": "Plan Free $5/mes agotado · espera al próximo reset o upgrade en https://apify.com/pricing"
      }
    }
  }
}
