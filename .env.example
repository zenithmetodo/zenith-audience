# Zenith Audience · Variables de entorno
# Copia este archivo a .env y rellena tus tokens
# IMPORTANTE: .env NO se commitea (está en .gitignore)

# ============================================================
# METRICOOL · métricas multi-plataforma
# Plan FREE (gratis para siempre)
# Setup: claude mcp add --transport http metricool https://ai.metricool.com/mcp
# Si usas OAuth (recomendado) · estos NO son necesarios
# ============================================================
METRICOOL_USER_TOKEN=
METRICOOL_USER_ID=

# ============================================================
# APIFY · research competidores y trends TT/IG
# Plan FREE $5/mes (~2000 scrapes · suficiente uso normal)
# Token en https://console.apify.com/account/integrations
# ============================================================
APIFY_TOKEN=

# ============================================================
# REDDIT · detección dolor emergente
# API oficial · 100% gratis
# Crea app en https://www.reddit.com/prefs/apps
# ============================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ZenithAudience/1.0

# ============================================================
# YOUTUBE DATA API · trends + búsquedas
# 100% gratis · cuota 10K/día
# Crea proyecto en https://console.cloud.google.com
# Activa YouTube Data API v3 · obtén API key
# ============================================================
YOUTUBE_API_KEY=

# ============================================================
# ANTHROPIC API · ya configurado en Claude Code
# No necesitas añadirlo aquí
# ============================================================
